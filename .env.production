# Production Environment Variables
NODE_ENV=production
APP_PORT=3001
APP_NAME=toeic-ai-api
API_PREFIX=api/v1

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=toeicai_user
DB_PASSWORD=StrongPassword123!
DB_DATABASE=toeicai
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_ACCESS_SECRET=production-access-secret-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=production-refresh-secret-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth (if needed)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/v1/auth/google/callback

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@toeic-ai.com

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_CHAIN_ID=80002

# Pinata Configuration
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# S3/MinIO Configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=toeic-ai
S3_REGION=us-east-1

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# AWS Configuration (if using AWS S3)
AWS_ACCESS_KEY=AKIAUUGUWUK72NLZABVK
AWS_SECRET_KEY=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
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=toeicnckh

# Docker Registry (for CI/CD)
